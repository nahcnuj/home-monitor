{
  "name": "home-monitor",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config dashboard/vite.config.ts",
    "build": "vite build --config dashboard/vite.config.ts",
    "typecheck": "tsc -p dashboard/tsconfig.json --noEmit",
    "read-config": "tsx scripts/read-config.ts",
    "tsv-to-json": "tsx scripts/tsv-to-json.ts",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "test:collect-safe": "powershell -NoProfile -File scripts/tests/Assert-CollectDnsSafe.ps1",
    "test:collect-lookup": "powershell -NoProfile -File scripts/tests/Test-CollectDnsLookup.ps1",
    "preview": "vite preview --config dashboard/vite.config.ts"
  },
  "dependencies": {
    "chart.js": "^4.4.7"
  },
  "devDependencies": {
    "happy-dom": "^20.10.6",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vitest-canvas-mock": "^1.1.4"
  }
}
